# Cognito OAuth Configuration
COGNITO_CLIENT_ID=your-client-id-here
COGNITO_CLIENT_SECRET=your-client-secret-here

# Cognito User Pool
VITE_USER_POOL_ID=your-pool-id-here
VITE_USER_POOL_CLIENT_ID=your-pool-client-id-here

# Callback URLs
CALLBACK_URL=http://localhost:3000/auth/callback
LOGOUT_URL=http://localhost:3000/

# Session Configuration
SESSION_SECRET=change-this-to-random-string

# Server Configuration
PORT=3000
NODE_ENV=development

# API Gateway Configuration
VITE_API_URL=https://tmdoc0q5ij.execute-api.us-east-1.amazonaws.com
VITE_S3_BUCKET=your-s3-bucket-name
VITE_AWS_REGION=us-east-1

# Backend URL (for AI features)
VITE_BACKEND_URL=http://localhost:3000

# Admin Credentials (Cognito)
ADMIN_EMAIL=your-admin-email
ADMIN_PASSWORD=your-admin-password

# AWS Credentials for S3 Upload
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Hugging Face AI - Virtual Try-On
# Get free token at: https://huggingface.co/settings/tokens
HUGGING_FACE_API_KEY=your-huggingface-token-here
VITE_HUGGING_FACE_API_KEY=your-huggingface-token-here
